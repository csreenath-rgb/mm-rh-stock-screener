# Database Configuration
# For PostgreSQL (recommended for production)
DATABASE_URL=postgresql://user:password@localhost:5432/stock_screener

# For local testing with SQLite (no installation required)
# DATABASE_URL=sqlite:///./stock_screener.db

# Logging Configuration
LOG_LEVEL=INFO

# Cache Configuration
CACHE_DIR=./data/cache
CACHE_EXPIRY_HOURS=24

# Email Notification Configuration
EMAIL_FROM=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_TO=recipient@example.com
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587

# Slack Notification Configuration (optional)
# Option 1: Webhook URL (easier setup)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Option 2: Bot Token (more features)
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_CHANNEL=#stock-alerts

# Telegram Notification Configuration (optional)
# 1. Message @BotFather in Telegram, run /newbot, copy the token below.
# 2. Send any message to your bot, open
#    https://api.telegram.org/bot<TOKEN>/getUpdates and copy "chat":{"id": ...}.
# See docs/NOTIFICATIONS_SETUP.md for the full walkthrough.
TELEGRAM_BOT_TOKEN=123456789:AA-your-bot-token
TELEGRAM_CHAT_ID=123456789

# Screening Configuration
SCREENING_TICKERS=AAPL,MSFT,GOOGL,AMZN,META,JPM,BAC,WMT,JNJ,XOM
SCREENING_TOP_N=10
SCREENING_MIN_SIGNAL=50

# Robinhood Integration (optional - read-only position tracking)
# Only username needed - password and SMS MFA are prompted interactively (never stored)
# ROBINHOOD_USERNAME=your-email@example.com
